programa {
  funcao inicio() {
    inteiro idade, maior_idade = 0, quantidade = 0
    cadeia sexo,olhos,cabelo
  
    para(inteiro i=1; i<=500; i++){
      escreva("Qual seu sexo (M PARA MASCULINO/F PARA FEMININO)\n")
      leia(sexo)
      escreva("Digite a cor dos olhos (A (azuis), V (verdes) e C (castanhos))\n")
      leia(olhos)
      escreva("Digite a sua cor de cabelo ( L (louros), C (castanhos) e P (pretos))\n")
      leia(cabelo)
      escreva("Digite a sua idade \n")
      leia(idade)
    se(idade > maior_idade){
      maior_idade = idade
    }
    se(sexo == "F" e idade >= 18 e idade <= 35 e olhos == "V" e cabelo == "L"){
      quantidade = quantidade + 1
    }
    escreva("\nMaior idade do grupo: ", maior_idade)
    escreva("\nQuantidade de mulheres com olhos verdes e cabelos louros: ", quantidade,"\n" )
    }
  }
}
